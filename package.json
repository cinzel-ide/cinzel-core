{
  "name": "cinzel-core",
  "displayName": "Cinzel Core",
  "description": "Motor de IA do Cinzel — chat, providers e (em breve) agentes.",
  "version": "0.1.0",
  "publisher": "cinzel",
  "license": "Apache-2.0",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["AI", "Chat", "Other"],
  "main": "./out/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        { "id": "cinzel", "title": "Cinzel", "icon": "media/cinzel.svg" }
      ]
    },
    "views": {
      "cinzel": [
        { "id": "cinzel.chat", "name": "%cinzel.view.chat.name%", "type": "webview" }
      ]
    },
    "commands": [
      { "command": "cinzel.setApiKey", "title": "%cinzel.command.setApiKey.title%" },
      { "command": "cinzel.clearApiKey", "title": "%cinzel.command.clearApiKey.title%" },
      { "command": "cinzel.selectModel", "title": "%cinzel.command.selectModel.title%" },
      { "command": "cinzel.completion.toggle", "title": "%cinzel.command.toggleCompletion.title%" },
      { "command": "cinzel.chat.clear", "title": "%cinzel.command.clearChat.title%" },
      { "command": "cinzel.attachSelection", "title": "%cinzel.command.attachSelection.title%" },
      { "command": "cinzel.attachFile", "title": "%cinzel.command.attachFile.title%" }
    ],
    "menus": {
      "view/title": [
        { "command": "cinzel.chat.clear", "when": "view == cinzel.chat", "group": "navigation" }
      ],
      "editor/context": [
        { "command": "cinzel.attachSelection", "when": "editorHasSelection", "group": "cinzel@1" },
        { "command": "cinzel.attachFile", "group": "cinzel@2" }
      ]
    },
    "configuration": {
      "title": "Cinzel",
      "properties": {
        "cinzel.responseLanguage": {
          "type": "string",
          "default": "auto",
          "enum": ["auto", "pt", "pt-br", "en", "es", "fr", "de", "it", "nl", "zh-cn", "zh-tw", "ja", "ko", "ru"],
          "description": "%cinzel.config.responseLanguage.desc%"
        },
        "cinzel.models": {
          "type": "array",
          "markdownDescription": "%cinzel.config.models.desc%",
          "items": {
            "type": "object",
            "required": ["id", "label", "provider", "baseUrl", "model"],
            "properties": {
              "id": { "type": "string" },
              "label": { "type": "string" },
              "provider": { "type": "string", "enum": ["openai", "anthropic"] },
              "baseUrl": { "type": "string" },
              "model": { "type": "string" },
              "maxTokens": { "type": "number" }
            }
          },
          "default": [
            { "id": "groq-gpt-oss-120b", "label": "Groq · gpt-oss-120b (grátis)", "provider": "openai", "baseUrl": "https://api.groq.com/openai/v1", "model": "openai/gpt-oss-120b" },
            { "id": "groq-llama-3.3-70b", "label": "Groq · llama-3.3-70b (grátis)", "provider": "openai", "baseUrl": "https://api.groq.com/openai/v1", "model": "llama-3.3-70b-versatile" },
            { "id": "anthropic-claude-sonnet", "label": "Anthropic · Claude Sonnet 4", "provider": "anthropic", "baseUrl": "https://api.anthropic.com/v1", "model": "claude-sonnet-4-20250514", "maxTokens": 4096 },
            { "id": "openai-gpt-4o", "label": "OpenAI · GPT-4o", "provider": "openai", "baseUrl": "https://api.openai.com/v1", "model": "gpt-4o" }
          ]
        },
        "cinzel.completion.enabled": {
          "type": "boolean",
          "default": true,
          "description": "%cinzel.config.completion.enabled.desc%"
        },
        "cinzel.completion.ollamaHost": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "%cinzel.config.completion.ollamaHost.desc%"
        },
        "cinzel.completion.model": {
          "type": "string",
          "default": "qwen2.5-coder:1.5b-base",
          "markdownDescription": "%cinzel.config.completion.model.desc%"
        },
        "cinzel.completion.maxTokens": {
          "type": "number",
          "default": 128,
          "description": "%cinzel.config.completion.maxTokens.desc%"
        }
      }
    }
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit",
    "vscode:prepublish": "node esbuild.js --production"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.4.0"
  }
}
