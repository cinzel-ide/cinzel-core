{
  "name": "cinzel-core",
  "displayName": "Cinzel Core",
  "description": "Motor de IA do Cinzel — chat, providers e (em breve) agentes.",
  "version": "0.1.0",
  "publisher": "cinzel",
  "license": "Apache-2.0",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["AI", "Chat", "Other"],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        { "id": "cinzel", "title": "Cinzel", "icon": "media/cinzel.svg" }
      ]
    },
    "views": {
      "cinzel": [
        { "id": "cinzel.chat", "name": "Chat", "type": "webview" }
      ]
    },
    "commands": [
      { "command": "cinzel.setApiKey", "title": "Cinzel: Definir chave de API…" },
      { "command": "cinzel.clearApiKey", "title": "Cinzel: Remover chave de API" },
      { "command": "cinzel.selectModel", "title": "Cinzel: Escolher modelo…" },
      { "command": "cinzel.chat.clear", "title": "Cinzel: Limpar conversa" },
      { "command": "cinzel.attachSelection", "title": "Cinzel: Anexar seleção ao chat" },
      { "command": "cinzel.attachFile", "title": "Cinzel: Anexar ficheiro ao chat" }
    ],
    "menus": {
      "view/title": [
        { "command": "cinzel.chat.clear", "when": "view == cinzel.chat", "group": "navigation" }
      ],
      "editor/context": [
        { "command": "cinzel.attachSelection", "when": "editorHasSelection", "group": "cinzel@1" },
        { "command": "cinzel.attachFile", "group": "cinzel@2" }
      ]
    },
    "configuration": {
      "title": "Cinzel",
      "properties": {
        "cinzel.models": {
          "type": "array",
          "markdownDescription": "Modelos escolhíveis no chat. Cada entrada: `id`, `label`, `provider` (`openai` ou `anthropic`), `baseUrl`, `model` e (na Anthropic) `maxTokens`. A chave de API é pedida por `baseUrl` e guardada no keychain do sistema.",
          "items": {
            "type": "object",
            "required": ["id", "label", "provider", "baseUrl", "model"],
            "properties": {
              "id": { "type": "string" },
              "label": { "type": "string" },
              "provider": { "type": "string", "enum": ["openai", "anthropic"] },
              "baseUrl": { "type": "string" },
              "model": { "type": "string" },
              "maxTokens": { "type": "number" }
            }
          },
          "default": [
            { "id": "groq-gpt-oss-120b", "label": "Groq · gpt-oss-120b (grátis)", "provider": "openai", "baseUrl": "https://api.groq.com/openai/v1", "model": "openai/gpt-oss-120b" },
            { "id": "groq-llama-3.3-70b", "label": "Groq · llama-3.3-70b (grátis)", "provider": "openai", "baseUrl": "https://api.groq.com/openai/v1", "model": "llama-3.3-70b-versatile" },
            { "id": "anthropic-claude-sonnet", "label": "Anthropic · Claude Sonnet 4", "provider": "anthropic", "baseUrl": "https://api.anthropic.com/v1", "model": "claude-sonnet-4-20250514", "maxTokens": 4096 },
            { "id": "openai-gpt-4o", "label": "OpenAI · GPT-4o", "provider": "openai", "baseUrl": "https://api.openai.com/v1", "model": "gpt-4o" }
          ]
        }
      }
    }
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit",
    "vscode:prepublish": "node esbuild.js --production"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.4.0"
  }
}
